{
  "multipart": [
    {
      "when": { "dnw": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true
      }
    },
    {
      "when": { "dne": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "y": 90
      }
    },
    {
      "when": { "dse": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "y": 180
      }
    },
    {
      "when": { "dsw": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "y": 270
      }
    },

    {
      "when": { "unw": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "x": 180,
        "y": 90
      }
    },
    {
      "when": { "une": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "x": 180,
        "y": 180
      }
    },
    {
      "when": { "use": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "x": 180,
        "y": 270
      }
    },
    {
      "when": { "usw": "true" },
      "apply": {
        "model": "veercore:block/stone_corner",
        "uvlock": true,
        "x": 180
      }
    }
  ]
}